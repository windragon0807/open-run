# ============================================
# OpenRun Frontend - Environment Variables
# ============================================
# .env.example을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env

# --------------------------------------------
# Client-side (NEXT_PUBLIC_* — 브라우저에 노출됨)
# --------------------------------------------

# 백엔드 API 서버 URL
# 발급: 팀 내부 — 로컬 개발 시 http://localhost:8080 사용 가능
NEXT_PUBLIC_API_SERVER_URL=https://api.open-run.xyz

# Google Maps JavaScript API Key (브라우저 지도 렌더링용)
# 발급: Google Cloud Console > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Reown AppKit / WalletConnect Project ID
# 발급: https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# Swarm Gateway URL (NFT 카탈로그 이미지 호스트)
# 백엔드 nft.swarm-gateway-url과 동일한 값으로 설정. next/image 호스트 허용(remotePatterns)에 사용됨.
# 미설정 시 기본값 https://api.gateway.ethswarm.org 사용.
NEXT_PUBLIC_SWARM_GATEWAY_URL=https://api.gateway.ethswarm.org

# PostHog Project Token (제품 이벤트 분석용 public write-only key)
# 발급: PostHog > Project settings > Project token
NEXT_PUBLIC_POSTHOG_KEY=YOUR_POSTHOG_PROJECT_TOKEN

# PostHog API Host
# US Cloud: https://us.i.posthog.com / EU Cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --------------------------------------------
# Server-side (서버에서만 사용 — 브라우저에 노출되지 않음)
# --------------------------------------------

# Google Maps / Geocoding / Places API Key
# 발급: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# OpenWeather API Key (날씨 정보)
# 발급: https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
